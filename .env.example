BOT_TOKEN=
OPENAI_API_KEY=
ALLOWED_USER_IDS=

# TARGET_CHAT_ID — ID супергруппы в формате -100<group_id> (префикс -100 обязателен).
# Получить можно через getUpdates после отправки любого сообщения в группу.
# Если оставить пустым — бот не фильтрует по группе, отвечает только на DM whitelisted-юзеров.
TARGET_CHAT_ID=

# WEBAPP_URL — публичный HTTPS-URL Mini App.
# Домен нужно зарегистрировать в BotFather через /setdomain (или при /newapp),
# иначе Telegram не откроет Mini App ни в DM, ни в группе.
WEBAPP_URL=https://<your-subdomain>.<your-domain>

# WEBAPP_SHORT_NAME — short-name Mini App из BotFather (/newapp).
# Нужен только для direct-link кнопки в групповом чате; для DM не обязателен.
WEBAPP_SHORT_NAME=

DB_PATH=data/shopping.db
TEMP_DIR=/tmp/shopping-list
LOG_LEVEL=INFO
