BOT_TOKEN=
OPENAI_API_KEY=
ALLOWED_USER_IDS=
TARGET_CHAT_ID=
WEBAPP_URL=https://your-mini-app.example.com
WEBAPP_SHORT_NAME=
DB_PATH=data/shopping.db
TEMP_DIR=/tmp/shopping-list
LOG_LEVEL=INFO

# Speech-to-text settings. WHISPER_MODEL accepts: gpt-4o-mini-transcribe (default,
# best quality/cost), gpt-4o-transcribe (most accurate, pricier), whisper-1 (legacy).
# WHISPER_PROMPT biases recognition toward listed vocabulary (~244 tokens max);
# add brands or rare words you often dictate so they are not misheard as common words.
WHISPER_MODEL=gpt-4o-mini-transcribe
WHISPER_LANGUAGE=ru
WHISPER_PROMPT=
